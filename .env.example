# ==========================================
# Inside-Fashion Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# --- Server Config ---
PORT=4000

# --- Database (MongoDB) ---
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# --- Authentication ---
JWT_SECRET=<generate-a-strong-random-secret>
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=<choose-a-strong-password>

# --- File Storage (Cloudinary) ---
CLOUDINARY_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_SECRET_KEY=<your-api-secret>

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=sk_test_<your-stripe-secret-key>

# --- Payments (Razorpay Backend) ---
RAZORPAY_KEY_ID=rzp_test_<your-razorpay-key-id>
RAZORPAY_KEY_SECRET=<your-razorpay-key-secret>

# --- CORS ---
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-admin.vercel.app
NODE_ENV=production
