# ==========================================
# INSIDE-FASHION MONOREPO ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to each specific workspace application
# OR use it as a reference for Vercel Deployments.

# ------------------------------------------
# BACKEND SECRETS (apps/backend/.env)
# Do NOT expose these to the frontend
# ------------------------------------------

# Server Configuration
PORT=4000

# Database (MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<database>?retryWrites=true&w=majority

# Authentication (JWT & Admin Access)
JWT_SECRET=your_secure_random_jwt_secret_key_here
ADMIN_EMAIL=admin@insidefashion.com
ADMIN_PASSWORD=SecureAdminPassword123!

# Cloudinary (Image Hosting)
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET_KEY=your_cloudinary_api_secret

# Stripe (Global Payment Gateway)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Razorpay (India Payment Gateway)
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret


# ------------------------------------------
# FRONTEND SECRETS (apps/frontend/.env)
# ------------------------------------------

# Target Backend API URL (Production Vercel URL)
VITE_BACKEND_URL=https://your-backend-project.vercel.app

# Razorpay Public Key (Required for client-side SDK)
VITE_RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id


# ------------------------------------------
# ADMIN SECRETS (apps/admin/.env)
# ------------------------------------------

# Target Backend API URL (Production Vercel URL)
VITE_BACKEND_URL=https://your-backend-project.vercel.app
